# Base URL of a deployed oc-realestate-intel instance.
# Example: https://oci.your-domain.com
# Empty default forces the operator to set it — clones can't accidentally
# call someone else's deployment.
OCI_API_URL=

# Optional API key. If the upstream agent enables key-gated access
# (sees `Authorization: Bearer <key>`) you'll need to set this. The current
# public deployment is open — leave blank to use anonymous access.
OCI_API_KEY=

# Optional — caps how long we wait for the agent. The hosted deployment
# usually responds in 2–5s but can be slower if the LLM is loaded or the
# query triggers live ArcGIS fallback (~+500ms).
OCI_TIMEOUT_S=30

LOG_LEVEL=INFO
